# Global authorities
GLOBAL_CODEX_SKILLS_DIR="$HOME/.codex/skills"
GLOBAL_CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
MANAGED_SKILLS="conduct content-draft content-review deep-review dev-plan fan-out review-plan rfc-finder spec-compliance update-docs"
CLAUDE_ONLY_SKILLS=""
# MANAGED_SKILLS are mirrored to both ~/.claude/skills/ and ~/.codex/skills/.
# CLAUDE_ONLY_SKILLS are promoted/synced Claude-side only (no .codex mirror).
# content-guidelines.md is canonical in this repo and mirrored by sync/promote/bootstrap scripts
# For one-off runs, override per command instead of editing this file permanently:
# MANAGED_SKILLS="rfc-finder" just bootstrap-skills
# CLAUDE_ONLY_SKILLS="some-claude-only-skill" just promote-skills

# Global CLAUDE.md path (synced bidirectionally)
# GLOBAL_CLAUDE_MD="$HOME/.claude/CLAUDE.md"
